# Kakao OAuth
KAKAO_REST_API_KEY=YOUR_KAKAO_REST_API_KEY
KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao

# JWT
SECRET_KEY=YOUR_SECRET_KEY_HERE  # generate with: openssl rand -hex 32

# Fernet Encryption Key (for API key encryption)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=YOUR_FERNET_KEY_HERE

# Database (AWS RDS / Lightsail PostgreSQL)
DB_USER=dbmasteruser
DB_PASS=YOUR_DB_PASSWORD
DB_HOST=YOUR_RDS_ENDPOINT
DB_PORT=5432
DB_NAME=postgres

# Upbit Exchange API (optional - users set their own via dashboard)
EXCHANGE_API_KEY=YOUR_UPBIT_OPEN_API_KEY
EXCHANGE_API_SECRET=YOUR_UPBIT_SECRET_KEY

# CORS Origins (comma-separated JSON array, optional)
# CORS_ORIGINS=["http://localhost:3000","https://jooeunoh.com"]
